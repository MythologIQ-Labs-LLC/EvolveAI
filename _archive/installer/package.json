{
  "name": "evolveai-installer",
  "version": "1.0.0",
  "description": "EvolveAI Desktop Application Installer",
  "main": "installer.js",
  "scripts": {
    "build": "electron-builder",
    "build:win": "electron-builder --win",
    "build:win-msi": "electron-builder --win --publish never",
    "build:win-exe": "electron-builder --win --publish never --config electron-builder-exe.json",
    "dist": "npm run build:win",
    "postinstall": "electron-builder install-app-deps"
  },
  "build": {
    "appId": "com.evolveai.desktop",
    "productName": "EvolveAI",
    "directories": {
      "output": "dist",
      "buildResources": "assets"
    },
    "files": [
      "app/**/*",
      "node_modules/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        },
        {
          "target": "msi",
          "arch": ["x64"]
        }
      ],
      "icon": "assets/evolveai-icon.ico",
      "requestedExecutionLevel": "requireAdministrator"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "EvolveAI",
      "installerIcon": "assets/evolveai-icon.ico",
      "uninstallerIcon": "assets/evolveai-icon.ico",
      "installerHeaderIcon": "assets/evolveai-icon.ico",
      "deleteAppDataOnUninstall": false,
      "include": "installer/nsis-installer.nsh"
    },
    "msi": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "EvolveAI",
      "icon": "assets/evolveai-icon.ico"
    }
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.6.4",
    "@electron-forge/cli": "^7.2.0",
    "@electron-forge/maker-deb": "^7.2.0",
    "@electron-forge/maker-rpm": "^7.2.0",
    "@electron-forge/maker-squirrel": "^7.2.0",
    "@electron-forge/maker-zip": "^7.2.0"
  },
  "dependencies": {
    "electron-updater": "^6.1.7",
    "electron-log": "^5.0.1",
    "node-fetch": "^3.3.2"
  }
} 